# Copy this file to .env and fill in your values.

SECRET_KEY=dev-secret-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAI — takes priority over Gemini when set
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# Google Gemini fallback
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_REASONING_MODEL=gemini-2.0-flash
GEMINI_FAST_MODEL=gemini-2.0-flash

# Dashboard URL (for CORS + email links)
DASHBOARD_URL=http://localhost:3001
WEBSITE_URL=http://localhost:3000

# GitHub API token (optional, for Intelligence feature)
GITHUB_ACCESS_TOKEN=your-github-token-here
